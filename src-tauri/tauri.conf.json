{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-schema/main/v2/tauri.conf.json",
  "productName": "Veloryn CloudFile",
  "version": "0.5.4",
  "identifier": "com.veloryn.cloudfile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Veloryn CloudFile",
        "width": 400,
        "height": 600,
        "resizable": true,
        "visible": false,
        "center": true,
        "decorations": true
      }
    ],
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Veloryn CloudFile"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["sidecars/rclone"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pl-PL"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "sidecars/rclone",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCNkU2NUZBRDRBQ0ZERDkKUldUWi9helUrbVZ1aXp4ckNUZ2FVcFhVMy9ac1FCNmVHZ3lQajRnTEVPd21mbFhpb3ZOcTlVNUwK",
      "endpoints": [
        "https://github.com/ReadyNextOs/ReadyNextOsDrive/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
